<style>
  .gallery-intro { max-width: 820px; margin: 0 auto 2.5rem; text-align: center; }
  .gallery-intro .eyebrow { display: inline-flex; align-items: center; gap: 0.45rem; margin-bottom: 0.9rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--secondary); font-weight: 700; font-size: 0.86rem; }
  .gallery-intro .title { margin-bottom: 1.25rem; color: #0f2d63; font-size: clamp(2.4rem, 3vw, 3.25rem); line-height: 1.05; max-width: 720px; margin-left: auto; margin-right: auto; }
  .gallery-intro .subtitle { margin: 0 auto; max-width: 640px; color: #556277; line-height: 1.8; }

  .gallery-highlights { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 1rem; margin-top: 1.8rem; }
  .btn-secondary { background: rgba(255,255,255,0.98); color: #2f6b9c; box-shadow: 0 18px 40px rgba(15, 23, 42, 0.08); border: 1px solid rgba(47, 167, 74, 0.12); }
  .btn-secondary:hover { background: #f3f8ff; }
  .highlight-card { padding: 1.15rem 1.2rem; border-radius: 20px; background: #fff; border: 1px solid rgba(15,23,42,0.08); box-shadow: 0 22px 52px rgba(15,23,42,0.06); text-align: center; }
  .highlight-card strong { display: block; font-size: 1.7rem; line-height: 1; color: var(--secondary); margin-bottom: 0.35rem; }
  .highlight-card span { color: #6a758f; font-size: 0.95rem; }

  .gallery-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 22px; }
  .gallery-card { position: relative; overflow: hidden; border-radius: 26px; background: #fff; border: 1px solid rgba(15,23,42,0.08); box-shadow: 0 28px 70px rgba(15,23,42,0.08); transition: transform 0.35s ease, box-shadow 0.35s ease; cursor: pointer; }
  .gallery-card:hover, .gallery-card:focus-visible { transform: translateY(-6px); box-shadow: 0 35px 90px rgba(15,23,42,0.13); }
  .gallery-card img { width: 100%; height: 100%; object-fit: cover; min-height: 240px; transition: transform 0.5s ease; }
  .gallery-card:hover img { transform: scale(1.04); }

  .gallery-card figcaption { position: absolute; inset: auto 0 0; display: flex; align-items: center; justify-content: space-between; gap: 14px; padding: 1.15rem 1.2rem; background: linear-gradient(180deg, rgba(0,0,0,0.08) 0%, rgba(4,32,80,0.78) 100%); color: #fff; }
  .gallery-card .caption { font-size: 1rem; font-weight: 700; line-height: 1.35; }
  .gallery-card small { display: block; margin-top: 0.35rem; color: rgba(255,255,255,0.82); font-size: 0.92rem; }
  .view-btn { background: rgba(255,255,255,0.18); border: 1px solid rgba(255,255,255,0.32); color: #fff; padding: 0.75rem 1.1rem; border-radius: 999px; transition: transform 0.2s ease, background 0.2s ease; }
  .view-btn:hover, .view-btn:focus-visible { transform: translateY(-1px); background: rgba(255,255,255,0.26); }

  .gallery-actions { margin: 2.5rem auto 0; max-width: 720px; text-align: center; }
  .gallery-actions p { margin-bottom: 1rem; color: #4a5a76; font-weight: 600; }
  .action-buttons { display: inline-flex; flex-wrap: wrap; gap: 1rem; justify-content: center; }
  .action-buttons .btn { min-width: 170px; }

  .lightbox { display: none; position: fixed; inset: 0; background: rgba(4,32,80,0.92); backdrop-filter: blur(6px); align-items: center; justify-content: center; padding: 20px; z-index: 1200; }
  .lightbox[aria-hidden="false"] { display: flex; }
  .lightbox-body { display: flex; flex-direction: column; align-items: center; gap: 14px; max-width: 92%; }
  .lightbox-img { width: auto; max-width: 100%; max-height: 78vh; border-radius: 18px; box-shadow: 0 35px 110px rgba(0,0,0,0.42); }
  .lightbox-caption { color: #fff; text-align: center; font-weight: 600; line-height: 1.55; }
  .lightbox-index { color: rgba(255,255,255,0.78); font-size: 0.95rem; }
  .lightbox-close, .lightbox-prev, .lightbox-next { position: absolute; background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.28); color: #fff; width: 46px; height: 46px; border-radius: 50%; display: grid; place-items: center; cursor: pointer; transition: background 0.2s ease, transform 0.2s ease; }
  .lightbox-close:hover, .lightbox-prev:hover, .lightbox-next:hover { transform: translateY(-1px); background: rgba(255,255,255,0.22); }
  .lightbox-close { top: 20px; right: 20px; }
  .lightbox-prev { top: 50%; left: 20px; transform: translateY(-50%); }
  .lightbox-next { top: 50%; right: 20px; transform: translateY(-50%); }
  .lightbox-prev:disabled, .lightbox-next:disabled { opacity: 0.35; cursor: not-allowed; }

  @media (max-width: 1080px) { .gallery-highlights, .gallery-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  @media (max-width: 720px) {
    .gallery-intro { text-align: left; }
    .gallery-highlights, .gallery-grid { grid-template-columns: 1fr; }
    .gallery-card img { min-height: 280px; }
    .gallery-actions { margin-top: 2rem; }
    .lightbox-prev, .lightbox-next { display: none; }
  }
</style>

<script is:inline>
  (function(){
    const cards = Array.from(document.querySelectorAll('.gallery-card'));
    const lightbox = document.querySelector('.lightbox');
    const lightboxImg = document.querySelector('.lightbox-img');
    const lightboxCaption = document.querySelector('.lightbox-caption');
    const lightboxIndex = document.querySelector('.lightbox-index');
    const closeBtn = document.querySelector('.lightbox-close');
    const prevBtn = document.querySelector('.lightbox-prev');
    const nextBtn = document.querySelector('.lightbox-next');
    let current = -1;

    function open(index){
      const card = cards[index];
      const img = card.querySelector('img');
      const src = card.dataset.full || img.src;
      const alt = img.alt || '';
      const caption = card.querySelector('.caption')?.textContent || '';
      lightboxImg.src = src;
      lightboxImg.alt = alt;
      lightboxCaption.textContent = caption;
      lightboxIndex.textContent = `${index + 1} / ${cards.length}`;
      lightbox.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      current = index;
      updateNav();
    }

    function close(){
      lightbox.setAttribute('aria-hidden', 'true');
      lightboxImg.src = '';
      document.body.style.overflow = '';
      current = -1;
    }

    function prev(){ if(current > 0) open(current - 1); }
    function next(){ if(current < cards.length - 1) open(current + 1); }

    function updateNav(){
      prevBtn.disabled = current <= 0;
      nextBtn.disabled = current >= cards.length - 1;
    }

    cards.forEach((card, i) => {
      const btn = card.querySelector('.view-btn');
      btn.addEventListener('click', (event) => { event.stopPropagation(); open(i); });
      card.addEventListener('click', () => open(i));
      card.addEventListener('keydown', (e) => { if(e.key === 'Enter' || e.key === ' ') { e.preventDefault(); open(i); } });
    });

    closeBtn.addEventListener('click', close);
    prevBtn.addEventListener('click', prev);
    nextBtn.addEventListener('click', next);
    lightbox.addEventListener('click', (e) => { if(e.target === lightbox) close(); });
    document.addEventListener('keydown', (e) => {
      if(lightbox.getAttribute('aria-hidden') === 'false'){
        if(e.key === 'Escape') close();
        if(e.key === 'ArrowLeft') prev();
        if(e.key === 'ArrowRight') next();
      }
    });
  })();
</script>