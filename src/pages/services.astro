---
import BaseLayout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
---

<BaseLayout title="Services - RAA Clean Services">
  <Header />

  <section style="padding: clamp(2.5rem, 6vw, 5rem); text-align:center;">
    <h1>Nos services</h1>

    <p>RAA Clean Services propose des prestations adaptées aux entreprises, copropriétés, chantiers et particuliers.</p>

    <ul style="list-style:none; padding:0; margin-top:30px; display:grid; gap:0.75rem; justify-items:start; max-width:620px; margin-left:auto; margin-right:auto;">
      <li>✔ Nettoyage de bureaux et espaces administratifs</li>
      <li>✔ Nettoyage d’immeubles et copropriétés</li>
      <li>✔ Nettoyage après travaux et fin de chantier</li>
      <li>✔ Nettoyage de vitres et façades</li>
      <li>✔ Entretien des locaux commerciaux</li>
      <li>✔ Désinfection et hygiène des espaces</li>
      <li>✔ Nettoyage pour particuliers (maisons, appartements)</li>
    </ul>
  </section>
</BaseLayout>
